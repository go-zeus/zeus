# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Output of the go coverage tool (LiteIDE / go test -coverprofile)
*.out
coverage.*
*.prof

# Dependency directories (remove the comment below to include it)
# vendor/

# IDE caches
.idea
.vscode/
.fleet/
.history/

# Editor swap files
*.swp
*.swo
*~

# —— 操作系统元数据（不要泄漏开发环境）——
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini
$RECYCLE.BIN/

# —— Zeus 项目加固（防止误提交本地编译产物）——

# examples Docker 构建产物（含 ca-certificates.crt、Dockerfile build context）
examples/*/build/

# examples 本地运行产物
examples/*/.pids/
examples/*/logs/
examples/*/tmp/
examples/*/.env.local

# examples Go 编译产物（无后缀二进制，与目录同名或同名去数字前缀）
# 注：无法用通配兜底（会误伤 main.go 等源文件），按 example 显式列出
examples/00-app-quickstart/00-app-quickstart
examples/01-hello/01-hello
examples/02-with-registry/02-with-registry
examples/03-typed/03-typed
examples/04-config-driven/04-config-driven
examples/05-autoapp/05-autoapp
examples/06-autoapp-full/06-autoapp-full
examples/07-autoapp-multi/07-autoapp-multi
examples/08-client/08-client
examples/09-middleware/09-middleware
examples/10-config/10-config
examples/11-proxy/11-proxy
examples/12-cluster-routing/cluster-routing
examples/13-database/13-database
examples/14-cache/14-cache
examples/15-mq/15-mq
examples/16-job/16-job
examples/17-job-cron/17-job-cron
examples/18-propagation/18-propagation
examples/19-observability/19-observability
examples/20-full-demo/cmd/api1/api1
examples/20-full-demo/cmd/frontend/frontend
examples/20-full-demo/cmd/gateway/gateway
examples/20-full-demo/cmd/srv1/srv1
examples/20-full-demo/cmd/srv2/srv2

# —— Hugo 文档站点构建产物（CI 自动 clone + 构建，不入库）——
site/themes/           # 由 docs.yml workflow git clone relearn 主题
site/public/           # Hugo 构建输出
site/resources/_gen/   # Hugo 资源缓存
.hugo_build.lock

# —— Go workspace 本地缓存 ——
go.work.sum
